# 复制为 .env 后填写，未填则使用默认值

# LLM / LangChain（统一用千帆 OpenAI 兼容 API Key，无需 AK/SK）
# 填写你的千帆 OpenAI 兼容 Base URL / 模型名 / API Key：
CAMPUS_RAG_OPENAI_API_KEY=
CAMPUS_RAG_OPENAI_BASE_URL=
# 主聊天模型（千帆 chat）
CAMPUS_RAG_OPENAI_MODEL=
# 多模态模型（可选，如有需要填写千帆的多模态 chat 模型）
CAMPUS_RAG_MULTIMODAL_MODEL=
# 向量化模型（可选，如使用千帆 Embedding 模型）
CAMPUS_RAG_EMBEDDING_MODEL=
# 重排模型（可选，填千帆兼容 reranker/embedding 模型名；OpenAI 兼容端点同样可用）
CAMPUS_RAG_RERANKER_MODEL=
# OCR 模型（可选，如千帆提供的 OCR/多模态识别模型）
CAMPUS_RAG_OCR_MODEL=
CAMPUS_RAG_USE_LANGCHAIN=true

# 检索 / 召回
CAMPUS_RAG_TOP_K=4
CAMPUS_RAG_MAX_CONTEXT_CHARS=3200
CAMPUS_RAG_CHUNK_SIZE=700
CAMPUS_RAG_CHUNK_OVERLAP=0
CAMPUS_RAG_CHUNK_OVERLAP_RATIO=0.12

# 生成
CAMPUS_RAG_GENERATION_MAX_TOKENS=512

# 重新排序（可选，填入模型名启用）
CAMPUS_RAG_RERANK_TOP_N=8

# 缓存与本地回退
CAMPUS_RAG_CACHE_ENABLED=true
CAMPUS_RAG_ALLOW_LOCAL_FALLBACK=true

# 存储路径（可选）
CAMPUS_RAG_DOCS_PATH=data/docs
CAMPUS_RAG_INDEX_PATH=data/index
CAMPUS_RAG_DB_PATH=data/session.db

# 日志
CAMPUS_RAG_LOG_LEVEL=INFO

# PgVector（启用向量数据库，host 使用本机端口映射）
CAMPUS_RAG_USE_PGVECTOR=true
CAMPUS_RAG_PG_DSN=postgresql://aiagent:aiagent@127.0.0.1:5432/aiagent
CAMPUS_RAG_PG_TABLE=rag_chunks

# MySQL（用户/管理员账户，host 使用本机端口映射）
CAMPUS_RAG_MYSQL_HOST=127.0.0.1
CAMPUS_RAG_MYSQL_PORT=3306
CAMPUS_RAG_MYSQL_USER=aiagent
CAMPUS_RAG_MYSQL_PASSWORD=aiagent
CAMPUS_RAG_MYSQL_DB=aiagent

# MongoDB（会话/聊天历史，host 使用本机端口映射）
CAMPUS_RAG_MONGO_URI=mongodb://127.0.0.1:27017
CAMPUS_RAG_MONGO_DB=aiagent
CAMPUS_RAG_MONGO_COLLECTION=messages

# 可选：CAMPUS_RAG_OSS_INTERNAL_ENDPOINT、CAMPUS_RAG_OSS_PREFIX 等
CAMPUS_RAG_USE_OSS_STORAGE=true
CAMPUS_RAG_OSS_ENDPOINT=your-endpoint
CAMPUS_RAG_OSS_BUCKET=your-bucket
CAMPUS_RAG_OSS_ACCESS_KEY_ID=...
CAMPUS_RAG_OSS_ACCESS_KEY_SECRET=...
